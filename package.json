{
  "name": "discordjs-flowstate",
  "version": "1.0.0",
  "description": "Composable, type-safe finite state machines for orchestrating multi-step Discord interactions on top of discord.js v14+. Build wizards, quizzes, onboarding flows, RPG encounters, and ticket systems as declarative state machines with persistence, timeouts, guards, sub-flows, middleware, and built-in component event routing.",
  "keywords": [
    "discord",
    "discord.js",
    "discordjs",
    "state-machine",
    "fsm",
    "finite-state-machine",
    "wizard",
    "flow",
    "interaction",
    "components",
    "buttons",
    "modal",
    "select-menu",
    "onboarding",
    "conversation",
    "saga",
    "orchestration",
    "typescript"
  ],
  "homepage": "https://github.com/kopeekool/discordjs-flowstate#readme",
  "bugs": {
    "url": "https://github.com/kopeekool/discordjs-flowstate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kopeekool/discordjs-flowstate.git"
  },
  "license": "MIT",
  "author": "kopeekool <github.com/kopeekool>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./adapters": {
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js",
      "require": "./dist/adapters/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"examples/**/*.ts\"",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "discord.js": "^14.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^1.2.0",
    "discord.js": "^14.14.1",
    "eslint": "^8.57.0",
    "prettier": "^3.2.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
